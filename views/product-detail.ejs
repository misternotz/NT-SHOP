<!DOCTYPE html>
<html lang="th" class="scroll-smooth">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="<%= product.name %> - NT SHOP">
  <title><%= product.name %> - NT SHOP</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body class="min-h-screen">
  <div class="fixed inset-0 -z-10">
    <div class="absolute inset-0 bg-dark-900"></div>
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-primary-600/10 rounded-full blur-[128px] animate-glow-pulse"></div>
    <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-accent-600/10 rounded-full blur-[128px] animate-glow-pulse" style="animation-delay:0.3s;"></div>
  </div>

  <%- include('partials/header') %>

  <main class="pt-20">
    <section class="py-12">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Breadcrumb -->
        <nav class="flex items-center gap-2 text-sm text-gray-500 mb-8 animate-fade-in-up">
          <a href="/" class="hover:text-primary-400 transition-colors">หน้าแรก</a>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          <a href="/products" class="hover:text-primary-400 transition-colors">สินค้า</a>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          <span class="text-white"><%= product.name %></span>
        </nav>

        <!-- Product Detail -->
        <div class="grid lg:grid-cols-2 gap-12">
          <!-- Image -->
          <div class="animate-fade-in-up">
            <div class="card-glass overflow-hidden rounded-2xl">
              <div class="relative aspect-video">
                <img src="<%= product.image %>" alt="<%= product.name %>" class="w-full h-full object-cover">
                <div class="absolute inset-0 bg-gradient-to-t from-dark-900/50 to-transparent"></div>
                <% if (product.badge) { %>
                <div class="absolute top-4 left-4">
                  <span class="px-4 py-1.5 bg-primary-500 text-white text-sm font-bold rounded-lg shadow-glow"><%= product.badge %></span>
                </div>
                <% } %>
              </div>
            </div>
          </div>

          <!-- Info -->
          <div class="animate-fade-in-up" style="animation-delay:0.1s;">
            <div class="flex items-center gap-3 mb-4">
              <span class="badge-<%= product.category %>"><%= product.category %></span>
              <div class="flex items-center gap-1 text-yellow-400 text-sm">
                <% for(let i = 0; i < 5; i++) { %><% if(i < Math.floor(product.rating)) { %>★<% } else { %>☆<% } %><% } %>
                <span class="text-gray-500 ml-1">(<%= product.reviews %> รีวิว)</span>
              </div>
            </div>

            <h1 class="font-display text-3xl md:text-4xl font-bold text-white mb-4"><%= product.name %></h1>
            <p class="text-gray-400 text-lg leading-relaxed mb-8"><%= product.description %></p>

            <!-- Price -->
            <div class="flex items-baseline gap-4 mb-8">
              <span class="font-display text-4xl font-bold text-white">$<%= product.price %></span>
              <% if (product.originalPrice) { %>
              <span class="text-gray-600 text-xl line-through">$<%= product.originalPrice %></span>
              <span class="px-3 py-1 bg-red-500/20 text-red-400 text-sm font-bold rounded-lg">
                -<%= Math.round((1 - product.price / product.originalPrice) * 100) %>%
              </span>
              <% } %>
            </div>

            <!-- Features -->
            <div class="mb-8">
              <h3 class="font-display font-bold text-white mb-4">ฟีเจอร์</h3>
              <div class="grid grid-cols-2 gap-3">
                <% product.features.forEach(function(f) { %>
                <div class="flex items-center gap-3 p-3 bg-white/[0.03] rounded-xl border border-white/[0.05]">
                  <svg class="w-5 h-5 text-primary-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                  </svg>
                  <span class="text-gray-300 text-sm"><%= f %></span>
                </div>
                <% }); %>
              </div>
            </div>

            <!-- Actions -->
            <div class="flex gap-4">
              <button onclick="addToCart(<%= product.id %>)" class="btn-primary flex-1 text-lg" id="add-to-cart-btn">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z"/>
                </svg>
                เพิ่มลงตะกร้า
              </button>
              <button onclick="addToCart(<%= product.id %>); window.location.href='/cart'" class="btn-secondary text-lg whitespace-nowrap">
                ซื้อเลย
              </button>
            </div>

            <!-- Extra info -->
            <div class="mt-8 p-6 bg-white/[0.02] rounded-2xl border border-white/[0.05] space-y-4">
              <div class="flex items-center gap-3 text-sm">
                <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                <span class="text-gray-400">ดาวน์โหลดได้ทันทีหลังชำระเงิน</span>
              </div>
              <div class="flex items-center gap-3 text-sm">
                <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                <span class="text-gray-400">อัพเดตฟรีตลอดอายุการใช้งาน</span>
              </div>
              <div class="flex items-center gap-3 text-sm">
                <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                <span class="text-gray-400">ซัพพอร์ตผ่าน Discord 24/7</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Related Products -->
        <% if (related.length > 0) { %>
        <div class="mt-24">
          <h2 class="section-heading mb-10">
            สินค้า <span class="gradient-text">ที่เกี่ยวข้อง</span>
          </h2>
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
            <% related.forEach(function(p) { %>
            <a href="/products/<%= p.id %>" class="card-product">
              <div class="relative overflow-hidden aspect-[16/10]">
                <img src="<%= p.image %>" alt="<%= p.name %>" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" loading="lazy">
                <div class="absolute inset-0 bg-gradient-to-t from-dark-900 via-dark-900/20 to-transparent"></div>
                <div class="absolute top-4 right-4">
                  <span class="badge-<%= p.category %>"><%= p.category %></span>
                </div>
              </div>
              <div class="p-6">
                <h3 class="font-display text-lg font-bold text-white mb-2 group-hover:text-primary-300 transition-colors"><%= p.name %></h3>
                <div class="flex items-baseline gap-2">
                  <span class="font-display text-xl font-bold text-white">$<%= p.price %></span>
                  <% if (p.originalPrice) { %>
                  <span class="text-gray-600 text-sm line-through">$<%= p.originalPrice %></span>
                  <% } %>
                </div>
              </div>
            </a>
            <% }); %>
          </div>
        </div>
        <% } %>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>
  <script src="/js/main.js"></script>
</body>
</html>
