<!DOCTYPE html>
<html lang="th" class="scroll-smooth">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="ติดต่อ NT SHOP - ร้านขาย FiveM Resource">
  <title>ติดต่อเรา - NT SHOP</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body class="min-h-screen">
  <div class="fixed inset-0 -z-10">
    <div class="absolute inset-0 bg-dark-900"></div>
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-primary-600/10 rounded-full blur-[128px] animate-glow-pulse"></div>
    <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-accent-600/10 rounded-full blur-[128px] animate-glow-pulse" style="animation-delay:0.3s;"></div>
  </div>

  <%- include('partials/header') %>

  <main class="pt-20">
    <section class="py-12">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-16">
          <!-- Contact Form -->
          <div class="animate-fade-in-up">
            <div class="inline-flex items-center gap-2 px-4 py-2 bg-primary-500/10 border border-primary-500/20 rounded-full mb-6">
              <span class="w-2 h-2 bg-primary-400 rounded-full animate-pulse"></span>
              <span class="text-primary-300 text-sm font-medium">Contact Us</span>
            </div>
            <h1 class="section-heading mb-4">ติดต่อ <span class="gradient-text">เรา</span></h1>
            <p class="text-gray-400 text-lg mb-10">มีคำถามหรือต้องการความช่วยเหลือ? ส่งข้อความหาเราได้เลย</p>

            <form class="space-y-6" id="contact-form">
              <div class="grid md:grid-cols-2 gap-6">
                <div>
                  <label class="block text-sm font-medium text-gray-300 mb-2">ชื่อ</label>
                  <input type="text" placeholder="ชื่อของคุณ" class="input-glass" required>
                </div>
                <div>
                  <label class="block text-sm font-medium text-gray-300 mb-2">อีเมล</label>
                  <input type="email" placeholder="email@example.com" class="input-glass" required>
                </div>
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-300 mb-2">หัวข้อ</label>
                <select class="input-glass">
                  <option value="" class="bg-dark-800">เลือกหัวข้อ</option>
                  <option value="general" class="bg-dark-800">ทั่วไป</option>
                  <option value="support" class="bg-dark-800">ขอความช่วยเหลือ</option>
                  <option value="refund" class="bg-dark-800">ขอคืนเงิน</option>
                  <option value="custom" class="bg-dark-800">สั่งทำ Resource</option>
                  <option value="bug" class="bg-dark-800">แจ้งบั๊ก</option>
                </select>
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-300 mb-2">ข้อความ</label>
                <textarea rows="5" placeholder="พิมพ์ข้อความของคุณ..." class="input-glass resize-none" required></textarea>
              </div>
              <button type="submit" class="btn-primary w-full text-lg">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
                </svg>
                ส่งข้อความ
              </button>
            </form>
          </div>

          <!-- Contact Info -->
          <div class="animate-fade-in-up" style="animation-delay:0.2s;">
            <div class="space-y-6">
              <a href="https://discord.gg" target="_blank" class="card-glass p-6 flex items-center gap-5 group">
                <div class="w-14 h-14 rounded-xl bg-[#5865F2]/20 flex items-center justify-center shrink-0 group-hover:shadow-[0_0_20px_rgba(88,101,242,0.3)] transition-all duration-300">
                  <svg class="w-7 h-7 text-[#5865F2]" fill="currentColor" viewBox="0 0 24 24"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/></svg>
                </div>
                <div>
                  <h3 class="font-display font-bold text-white group-hover:text-[#5865F2] transition-colors">Discord</h3>
                  <p class="text-gray-500 text-sm">เข้าร่วม Discord ของเรา</p>
                </div>
                <svg class="w-5 h-5 text-gray-600 ml-auto group-hover:text-[#5865F2] group-hover:translate-x-1 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </a>

              <div class="card-glass p-6 flex items-center gap-5">
                <div class="w-14 h-14 rounded-xl bg-primary-500/20 flex items-center justify-center shrink-0">
                  <svg class="w-7 h-7 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                  </svg>
                </div>
                <div>
                  <h3 class="font-display font-bold text-white">อีเมล</h3>
                  <p class="text-gray-500 text-sm">support@ntshop.com</p>
                </div>
              </div>

              <a href="#" class="card-glass p-6 flex items-center gap-5 group">
                <div class="w-14 h-14 rounded-xl bg-[#1877F2]/20 flex items-center justify-center shrink-0 group-hover:shadow-[0_0_20px_rgba(24,119,242,0.3)] transition-all duration-300">
                  <svg class="w-7 h-7 text-[#1877F2]" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                </div>
                <div>
                  <h3 class="font-display font-bold text-white group-hover:text-[#1877F2] transition-colors">Facebook</h3>
                  <p class="text-gray-500 text-sm">ติดตามเราบน Facebook</p>
                </div>
                <svg class="w-5 h-5 text-gray-600 ml-auto group-hover:text-[#1877F2] group-hover:translate-x-1 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </a>

              <div class="card-glass p-6">
                <div class="flex items-center gap-5 mb-4">
                  <div class="w-14 h-14 rounded-xl bg-emerald-500/20 flex items-center justify-center shrink-0">
                    <svg class="w-7 h-7 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                  </div>
                  <div>
                    <h3 class="font-display font-bold text-white">เวลาทำการ</h3>
                    <p class="text-gray-500 text-sm">ซัพพอร์ตพร้อมให้บริการ</p>
                  </div>
                </div>
                <div class="space-y-2 pl-[4.5rem]">
                  <div class="flex justify-between text-sm">
                    <span class="text-gray-400">จันทร์ - ศุกร์</span>
                    <span class="text-white font-medium">09:00 - 22:00</span>
                  </div>
                  <div class="flex justify-between text-sm">
                    <span class="text-gray-400">เสาร์ - อาทิตย์</span>
                    <span class="text-white font-medium">10:00 - 20:00</span>
                  </div>
                  <div class="flex justify-between text-sm">
                    <span class="text-gray-400">Discord</span>
                    <span class="text-emerald-400 font-medium">24/7</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>
  <script src="/js/main.js"></script>
</body>
</html>
