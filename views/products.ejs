<!DOCTYPE html>
<html lang="th" class="scroll-smooth">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="สินค้า FiveM Resource - NT SHOP">
  <title>สินค้าทั้งหมด - NT SHOP</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body class="min-h-screen">
  <div class="fixed inset-0 -z-10">
    <div class="absolute inset-0 bg-dark-900"></div>
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-primary-600/10 rounded-full blur-[128px] animate-glow-pulse"></div>
    <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-accent-600/10 rounded-full blur-[128px] animate-glow-pulse" style="animation-delay:0.3s;"></div>
  </div>

  <%- include('partials/header') %>

  <main class="pt-20">
    <section class="py-12">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Header -->
        <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-6 mb-12">
          <div class="animate-fade-in-up">
            <h1 class="section-heading">
              สินค้า <span class="gradient-text">ทั้งหมด</span>
            </h1>
            <p class="text-gray-500 mt-3">เลือกช้อป FiveM Resource ที่เหมาะกับเซิร์ฟเวอร์ของคุณ</p>
          </div>
          <div class="animate-fade-in-up" style="animation-delay:0.1s;">
            <form action="/products" method="GET" class="flex gap-3">
              <input type="hidden" name="category" value="<%= category %>">
              <div class="relative">
                <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                </svg>
                <input type="text" name="search" value="<%= search %>" placeholder="ค้นหาสินค้า..." class="input-glass !pl-12 w-64">
              </div>
              <button type="submit" class="px-6 py-3 bg-primary-600 hover:bg-primary-500 rounded-xl text-sm font-medium transition-all duration-300 hover:shadow-glow">
                ค้นหา
              </button>
            </form>
          </div>
        </div>

        <!-- Category Filter -->
        <div class="flex flex-wrap gap-3 mb-10 animate-fade-in-up" style="animation-delay:0.2s;">
          <a href="/products" class="px-6 py-2.5 rounded-xl text-sm font-medium transition-all duration-300 <%= category === 'all' ? 'bg-primary-600 text-white shadow-glow' : 'bg-white/5 text-gray-400 hover:bg-white/10 hover:text-white border border-white/10' %>">
            ทั้งหมด
          </a>
          <a href="/products?category=script" class="px-6 py-2.5 rounded-xl text-sm font-medium transition-all duration-300 <%= category === 'script' ? 'bg-primary-600 text-white shadow-glow' : 'bg-white/5 text-gray-400 hover:bg-white/10 hover:text-white border border-white/10' %>">
            <span class="mr-1">⚡</span> Scripts
          </a>
          <a href="/products?category=prop" class="px-6 py-2.5 rounded-xl text-sm font-medium transition-all duration-300 <%= category === 'prop' ? 'bg-accent-600 text-white shadow-glow-blue' : 'bg-white/5 text-gray-400 hover:bg-white/10 hover:text-white border border-white/10' %>">
            <span class="mr-1">📦</span> Props
          </a>
          <a href="/products?category=map" class="px-6 py-2.5 rounded-xl text-sm font-medium transition-all duration-300 <%= category === 'map' ? 'bg-emerald-600 text-white shadow-[0_0_20px_rgba(16,185,129,0.3)]' : 'bg-white/5 text-gray-400 hover:bg-white/10 hover:text-white border border-white/10' %>">
            <span class="mr-1">🗺️</span> Maps
          </a>
        </div>

        <!-- Products Grid -->
        <% if (products.length > 0) { %>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
          <% products.forEach(function(product, index) { %>
          <div class="card-product animate-fade-in-up" style="animation-delay: <%= index * 0.1 %>s;">
            <div class="relative overflow-hidden aspect-[16/10]">
              <img src="<%= product.image %>" alt="<%= product.name %>" 
                   class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" loading="lazy">
              <div class="absolute inset-0 bg-gradient-to-t from-dark-900 via-dark-900/20 to-transparent"></div>
              <% if (product.badge) { %>
              <div class="absolute top-4 left-4">
                <span class="px-3 py-1 bg-primary-500 text-white text-xs font-bold rounded-lg shadow-glow"><%= product.badge %></span>
              </div>
              <% } %>
              <div class="absolute top-4 right-4">
                <span class="badge-<%= product.category %>"><%= product.category %></span>
              </div>
            </div>
            <div class="p-6">
              <h3 class="font-display text-lg font-bold text-white mb-2 group-hover:text-primary-300 transition-colors"><%= product.name %></h3>
              <p class="text-gray-500 text-sm mb-4 line-clamp-2"><%= product.description %></p>
              <div class="flex items-center gap-2 mb-4">
                <div class="flex text-yellow-400 text-sm">
                  <% for(let i = 0; i < 5; i++) { %><% if(i < Math.floor(product.rating)) { %>★<% } else { %>☆<% } %><% } %>
                </div>
                <span class="text-gray-600 text-xs">(<%= product.reviews %>)</span>
              </div>
              <div class="flex items-center justify-between">
                <div class="flex items-baseline gap-2">
                  <span class="font-display text-2xl font-bold text-white">$<%= product.price %></span>
                  <% if (product.originalPrice) { %>
                  <span class="text-gray-600 text-sm line-through">$<%= product.originalPrice %></span>
                  <% } %>
                </div>
                <div class="flex gap-2">
                  <button onclick="addToCart(<%= product.id %>)" 
                          class="p-2.5 bg-primary-600/20 text-primary-400 rounded-xl hover:bg-primary-600 hover:text-white transition-all duration-300" title="เพิ่มลงตะกร้า">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z"/>
                    </svg>
                  </button>
                  <a href="/products/<%= product.id %>" class="px-4 py-2.5 bg-white/5 text-gray-300 rounded-xl text-sm font-medium hover:bg-white/10 hover:text-white transition-all duration-300 flex items-center gap-1">
                    ดูเพิ่ม
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                  </a>
                </div>
              </div>
            </div>
          </div>
          <% }); %>
        </div>
        <% } else { %>
        <div class="text-center py-24">
          <div class="w-20 h-20 mx-auto mb-6 rounded-full bg-white/5 flex items-center justify-center">
            <svg class="w-10 h-10 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <h3 class="font-display text-xl font-bold text-white mb-2">ไม่พบสินค้า</h3>
          <p class="text-gray-500">ลองค้นหาด้วยคำอื่น หรือเปลี่ยนหมวดหมู่</p>
        </div>
        <% } %>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>
  <script src="/js/main.js"></script>
</body>
</html>
