<!DOCTYPE html>
<html lang="th" class="scroll-smooth">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>404 - NT SHOP</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body class="min-h-screen">
  <div class="fixed inset-0 -z-10">
    <div class="absolute inset-0 bg-dark-900"></div>
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-primary-600/10 rounded-full blur-[128px] animate-glow-pulse"></div>
    <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-accent-600/10 rounded-full blur-[128px] animate-glow-pulse" style="animation-delay:0.3s;"></div>
  </div>

  <%- include('partials/header') %>

  <main class="pt-20">
    <section class="py-12 min-h-[70vh] flex items-center">
      <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <div class="animate-fade-in-up">
          <div class="font-display text-[8rem] font-extrabold gradient-text leading-none mb-4">404</div>
          <h1 class="font-display text-3xl font-bold text-white mb-4">หน้านี้ไม่มีอยู่</h1>
          <p class="text-gray-500 text-lg mb-10">ขออภัย ไม่พบหน้าที่คุณกำลังค้นหา</p>
          <div class="flex justify-center gap-4">
            <a href="/" class="btn-primary">กลับหน้าแรก</a>
            <a href="/products" class="btn-secondary">ดูสินค้า</a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>
  <script src="/js/main.js"></script>
</body>
</html>
