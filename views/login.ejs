<!DOCTYPE html>
<html lang="th" class="scroll-smooth">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>เข้าสู่ระบบ - NT SHOP</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body class="min-h-screen">
  <div class="fixed inset-0 -z-10">
    <div class="absolute inset-0 bg-dark-900"></div>
    <div class="absolute top-0 right-1/4 w-96 h-96 bg-primary-600/10 rounded-full blur-[128px] animate-glow-pulse"></div>
    <div class="absolute bottom-0 left-1/4 w-96 h-96 bg-accent-600/10 rounded-full blur-[128px] animate-glow-pulse" style="animation-delay:0.3s;"></div>
  </div>

  <%- include('partials/header') %>

  <main class="pt-20 flex items-center justify-center min-h-[calc(100vh-80px)]">
    <div class="w-full max-w-md px-4 py-12">
      <div class="card-glass p-8 animate-fade-in-up">
        <div class="text-center mb-8">
          <div class="w-16 h-16 mx-auto mb-4 rounded-xl bg-gradient-to-br from-primary-500 to-accent-500 flex items-center justify-center shadow-glow">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 11c0 3.517-1.009 6.799-2.753 9.571m-3.44-2.04l.054-.09A13.916 13.916 0 008 11a4 4 0 118 0c0 1.017-.07 2.019-.203 3m-2.118 6.844A21.88 21.88 0 0015.171 17m3.839 1.132c.645-2.266.99-4.659.99-7.132A8 8 0 008 4.07M3 15.364c.64-1.319 1-2.8 1-4.364 0-1.457.39-2.823 1.07-4"/>
            </svg>
          </div>
          <h1 class="font-display text-2xl font-bold text-white mb-2">เข้าสู่ระบบ</h1>
          <p class="text-gray-400">เข้าสู่บัญชีของคุณเพื่อดำเนินการต่อ</p>
        </div>

        <% if (error) { %>
          <div class="bg-red-500/10 border border-red-500/20 text-red-400 px-4 py-3 rounded-lg text-sm mb-6 text-center shadow-[0_0_15px_rgba(239,68,68,0.1)]">
            <%= error %>
          </div>
        <% } %>

        <form action="/auth/login" method="POST" class="space-y-6">
          <div>
            <label for="username" class="block text-sm font-medium text-gray-300 mb-2">ชื่อผู้ใช้ (Username)</label>
            <input type="text" id="username" name="username" required
              class="w-full bg-dark-800 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500 transition-all font-sans"
              placeholder="Username" autocomplete="username">
          </div>
          <div>
            <label for="password" class="block text-sm font-medium text-gray-300 mb-2">รหัสผ่าน (Password)</label>
            <input type="password" id="password" name="password" required
              class="w-full bg-dark-800 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:border-primary-500 focus:ring-1 focus:ring-primary-500 transition-all font-sans"
              placeholder="••••••••" autocomplete="current-password">
          </div>

          <div class="flex items-center justify-between mt-4">
            <div class="flex items-center">
              <input id="remember-me" name="remember-me" type="checkbox" class="h-4 w-4 bg-dark-800 border-white/10 rounded text-primary-500 focus:ring-primary-500/50">
              <label for="remember-me" class="ml-2 block text-sm text-gray-400">
                จดจำฉันไว้
              </label>
            </div>
          </div>

          <button type="submit" class="w-full py-3 px-4 bg-gradient-to-r from-primary-500 to-accent-500 hover:from-primary-400 hover:to-accent-400 text-white font-medium rounded-xl shadow-glow transition-all hover:-translate-y-0.5 mt-6">
            เข้าสู่ระบบ
          </button>
        </form>

        <p class="mt-8 text-center text-sm text-gray-400">
          ยังไม่มีบัญชีผู้ใช้? 
          <a href="/auth/register" class="text-primary-400 hover:text-primary-300 font-medium transition-colors">สมัครสมาชิกที่นี่</a>
        </p>
      </div>
    </div>
  </main>

  <%- include('partials/footer') %>
  <script src="/js/main.js"></script>
</body>
</html>
