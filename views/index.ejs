<!DOCTYPE html>
<html lang="th" class="scroll-smooth">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="NT SHOP - ร้านขาย FiveM Resource คุณภาพสูง Script, Prop, Map สำหรับเซิร์ฟเวอร์ FiveM ของคุณ">
  <title>NT SHOP - Premium FiveM Resources</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body class="min-h-screen">
  <!-- Background effects -->
  <div class="fixed inset-0 -z-10">
    <div class="absolute inset-0 bg-dark-900"></div>
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-primary-600/10 rounded-full blur-[128px] animate-glow-pulse"></div>
    <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-accent-600/10 rounded-full blur-[128px] animate-glow-pulse" style="animation-delay: 0.3s;"></div>
  </div>

  <%- include('partials/header') %>

  <main class="pt-20">
    <!-- Hero Section -->
    <section class="relative min-h-[90vh] flex items-center overflow-hidden">
      <div class="absolute inset-0 overflow-hidden">
        <div class="absolute top-1/4 left-1/4 w-64 h-64 bg-primary-500/5 rounded-full blur-[100px] animate-float"></div>
        <div class="absolute bottom-1/4 right-1/3 w-80 h-80 bg-accent-500/5 rounded-full blur-[120px] animate-float" style="animation-delay:0.3s;"></div>
        <div class="absolute top-1/2 right-1/4 w-48 h-48 bg-primary-600/8 rounded-full blur-[80px] animate-float" style="animation-delay:0.5s;"></div>
      </div>
      
      <div class="absolute inset-0 opacity-[0.02]" style="background-image: linear-gradient(rgba(255,255,255,.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.1) 1px, transparent 1px); background-size: 60px 60px;"></div>

      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full relative z-10">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div class="space-y-8 animate-fade-in-up">
            <div class="inline-flex items-center gap-2 px-4 py-2 bg-primary-500/10 border border-primary-500/20 rounded-full">
              <span class="w-2 h-2 bg-primary-400 rounded-full animate-pulse"></span>
              <span class="text-primary-300 text-sm font-medium">Premium FiveM Resources</span>
            </div>
            
            <h1 class="font-display text-5xl md:text-6xl lg:text-7xl font-extrabold leading-tight">
              สร้างเซิร์ฟเวอร์
              <br>
              <span class="gradient-text">FiveM</span> ในฝัน
            </h1>

            <p class="text-gray-400 text-lg md:text-xl max-w-xl leading-relaxed">
              แหล่งรวม Script, Prop และ Map คุณภาพสูง ที่จะทำให้เซิร์ฟเวอร์ของคุณโดดเด่นกว่าใครๆ
            </p>

            <div class="flex flex-wrap gap-4">
              <a href="/products" class="btn-primary text-lg">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                </svg>
                ดูสินค้าทั้งหมด
              </a>
              <a href="/about" class="btn-secondary text-lg">
                เรียนรู้เพิ่มเติม
              </a>
            </div>

            <div class="flex gap-8 pt-4">
              <div>
                <div class="font-display text-3xl font-bold gradient-text">500+</div>
                <div class="text-gray-500 text-sm mt-1">ลูกค้า</div>
              </div>
              <div>
                <div class="font-display text-3xl font-bold gradient-text">50+</div>
                <div class="text-gray-500 text-sm mt-1">Resources</div>
              </div>
              <div>
                <div class="font-display text-3xl font-bold gradient-text">4.8</div>
                <div class="text-gray-500 text-sm mt-1">⭐ คะแนน</div>
              </div>
            </div>
          </div>

          <!-- Hero Visual - Code Block -->
          <div class="hidden lg:block relative animate-fade-in-up" style="animation-delay: 0.2s;">
            <div class="relative">
              <div class="absolute inset-0 bg-gradient-to-br from-primary-500/20 to-accent-500/20 rounded-3xl blur-3xl"></div>
              <div class="relative card-glass p-8 rounded-3xl overflow-hidden">
                <div class="absolute top-0 right-0 w-32 h-32 bg-primary-500/10 rounded-full blur-2xl"></div>
                <div class="space-y-4">
                  <div class="flex items-center gap-3 mb-6">
                    <div class="w-3 h-3 rounded-full bg-red-500"></div>
                    <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                    <div class="w-3 h-3 rounded-full bg-green-500"></div>
                    <span class="text-gray-600 text-sm ml-2 font-mono">ntshop_resource</span>
                  </div>
                  <div class="font-mono text-sm space-y-2">
                    <p><span class="text-primary-400">local</span> <span class="text-accent-400">resource</span> = {</p>
                    <p class="pl-4"><span class="text-gray-500">name</span> = <span class="text-emerald-400">"NT Premium Script"</span>,</p>
                    <p class="pl-4"><span class="text-gray-500">type</span> = <span class="text-emerald-400">"script"</span>,</p>
                    <p class="pl-4"><span class="text-gray-500">quality</span> = <span class="text-primary-300">"premium"</span>,</p>
                    <p class="pl-4"><span class="text-gray-500">optimized</span> = <span class="text-accent-400">true</span>,</p>
                    <p>}</p>
                    <p class="mt-4"><span class="text-primary-400">print</span>(<span class="text-emerald-400">"🚀 Resource loaded!"</span>)</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Category Section -->
    <section class="py-24 relative">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16 animate-fade-in-up">
          <h2 class="section-heading">
            หมวดหมู่ <span class="gradient-text">สินค้า</span>
          </h2>
          <p class="text-gray-500 mt-4 max-w-2xl mx-auto">เลือกสิ่งที่คุณต้องการเพื่อยกระดับเซิร์ฟเวอร์ FiveM ของคุณ</p>
        </div>

        <div class="grid md:grid-cols-3 gap-6 lg:gap-8">
          <a href="/products?category=script" class="card-glass p-8 text-center group animate-fade-in-up">
            <div class="w-20 h-20 mx-auto mb-6 rounded-2xl bg-gradient-to-br from-primary-500/20 to-primary-600/20 border border-primary-500/20 flex items-center justify-center group-hover:shadow-glow transition-all duration-500 group-hover:scale-110">
              <svg class="w-10 h-10 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
              </svg>
            </div>
            <h3 class="font-display text-2xl font-bold text-white mb-3">Scripts</h3>
            <p class="text-gray-500 text-sm leading-relaxed">ระบบต่างๆ ที่จะเพิ่มฟีเจอร์ให้กับเซิร์ฟเวอร์ของคุณ ทั้ง ESX และ QBCore</p>
            <div class="mt-6 text-primary-400 text-sm font-medium flex items-center justify-center gap-2 opacity-0 group-hover:opacity-100 transition-all duration-300">
              ดูทั้งหมด
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </div>
          </a>

          <a href="/products?category=prop" class="card-glass p-8 text-center group animate-fade-in-up" style="animation-delay:0.1s;">
            <div class="w-20 h-20 mx-auto mb-6 rounded-2xl bg-gradient-to-br from-accent-500/20 to-accent-600/20 border border-accent-500/20 flex items-center justify-center group-hover:shadow-glow-blue transition-all duration-500 group-hover:scale-110">
              <svg class="w-10 h-10 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
              </svg>
            </div>
            <h3 class="font-display text-2xl font-bold text-white mb-3">Props</h3>
            <p class="text-gray-500 text-sm leading-relaxed">รถยนต์ อาวุธ และไอเทมต่างๆ คุณภาพสูง สำหรับ FiveM</p>
            <div class="mt-6 text-accent-400 text-sm font-medium flex items-center justify-center gap-2 opacity-0 group-hover:opacity-100 transition-all duration-300">
              ดูทั้งหมด
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </div>
          </a>

          <a href="/products?category=map" class="card-glass p-8 text-center group animate-fade-in-up" style="animation-delay:0.2s;">
            <div class="w-20 h-20 mx-auto mb-6 rounded-2xl bg-gradient-to-br from-emerald-500/20 to-emerald-600/20 border border-emerald-500/20 flex items-center justify-center group-hover:shadow-[0_0_20px_rgba(16,185,129,0.3)] transition-all duration-500 group-hover:scale-110">
              <svg class="w-10 h-10 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
              </svg>
            </div>
            <h3 class="font-display text-2xl font-bold text-white mb-3">Maps</h3>
            <p class="text-gray-500 text-sm leading-relaxed">อินทีเรียและโลเคชั่นใหม่ๆ เพื่อเพิ่มบรรยากาศให้เซิร์ฟเวอร์</p>
            <div class="mt-6 text-emerald-400 text-sm font-medium flex items-center justify-center gap-2 opacity-0 group-hover:opacity-100 transition-all duration-300">
              ดูทั้งหมด
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- Featured Products -->
    <section class="py-24 relative">
      <div class="absolute inset-0 bg-gradient-to-b from-transparent via-primary-900/5 to-transparent"></div>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="flex flex-col md:flex-row md:items-end justify-between mb-16">
          <div class="animate-fade-in-up">
            <h2 class="section-heading">
              สินค้า <span class="gradient-text">แนะนำ</span>
            </h2>
            <p class="text-gray-500 mt-4 max-w-xl">Resource ที่ได้รับความนิยมสูงสุดจากลูกค้าของเรา</p>
          </div>
          <a href="/products" class="mt-6 md:mt-0 text-primary-400 hover:text-primary-300 font-medium text-sm flex items-center gap-2 transition-colors">
            ดูสินค้าทั้งหมด
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
          <% products.forEach(function(product, index) { %>
          <div class="card-product animate-fade-in-up" style="animation-delay: <%= index * 0.1 %>s;">
            <div class="relative overflow-hidden aspect-[16/10]">
              <img src="<%= product.image %>" alt="<%= product.name %>" 
                   class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110">
              <div class="absolute inset-0 bg-gradient-to-t from-dark-900 via-dark-900/20 to-transparent"></div>
              <% if (product.badge) { %>
              <div class="absolute top-4 left-4">
                <span class="px-3 py-1 bg-primary-500 text-white text-xs font-bold rounded-lg shadow-glow">
                  <%= product.badge %>
                </span>
              </div>
              <% } %>
              <div class="absolute top-4 right-4">
                <span class="badge-<%= product.category %>"><%= product.category %></span>
              </div>
            </div>
            <div class="p-6">
              <h3 class="font-display text-lg font-bold text-white mb-2 group-hover:text-primary-300 transition-colors">
                <%= product.name %>
              </h3>
              <p class="text-gray-500 text-sm line-clamp-2 mb-4"><%= product.description %></p>
              <div class="flex items-center gap-2 mb-4">
                <div class="flex text-yellow-400 text-sm">
                  <% for(let i = 0; i < 5; i++) { %>
                    <% if(i < Math.floor(product.rating)) { %>★<% } else { %>☆<% } %>
                  <% } %>
                </div>
                <span class="text-gray-600 text-xs">(<%= product.reviews %>)</span>
              </div>
              <div class="flex items-center justify-between">
                <div class="flex items-baseline gap-2">
                  <span class="font-display text-2xl font-bold text-white">$<%= product.price %></span>
                  <% if (product.originalPrice) { %>
                  <span class="text-gray-600 text-sm line-through">$<%= product.originalPrice %></span>
                  <% } %>
                </div>
                <a href="/products/<%= product.id %>" class="px-4 py-2 bg-primary-600/20 text-primary-400 rounded-xl text-sm font-medium hover:bg-primary-600 hover:text-white transition-all duration-300">
                  ดูรายละเอียด
                </a>
              </div>
            </div>
          </div>
          <% }); %>
        </div>
      </div>
    </section>

    <!-- Why Choose Us -->
    <section class="py-24 relative">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16 animate-fade-in-up">
          <h2 class="section-heading">
            ทำไมต้อง <span class="gradient-text">NT SHOP</span>?
          </h2>
          <p class="text-gray-500 mt-4 max-w-2xl mx-auto">เราให้ความสำคัญกับคุณภาพและประสบการณ์ที่ดีที่สุดของลูกค้า</p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
          <div class="card-glass p-6 text-center animate-fade-in-up">
            <div class="w-14 h-14 mx-auto mb-4 rounded-xl bg-primary-500/10 flex items-center justify-center">
              <svg class="w-7 h-7 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
              </svg>
            </div>
            <h3 class="font-display font-bold text-white mb-2">คุณภาพสูง</h3>
            <p class="text-gray-500 text-sm">ทุก Resource ผ่านการตรวจสอบและทดสอบอย่างละเอียด</p>
          </div>
          <div class="card-glass p-6 text-center animate-fade-in-up" style="animation-delay:0.1s;">
            <div class="w-14 h-14 mx-auto mb-4 rounded-xl bg-accent-500/10 flex items-center justify-center">
              <svg class="w-7 h-7 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
              </svg>
            </div>
            <h3 class="font-display font-bold text-white mb-2">ได้ทันที</h3>
            <p class="text-gray-500 text-sm">ดาวน์โหลดได้ทันทีหลังการชำระเงิน ไม่ต้องรอ</p>
          </div>
          <div class="card-glass p-6 text-center animate-fade-in-up" style="animation-delay:0.2s;">
            <div class="w-14 h-14 mx-auto mb-4 rounded-xl bg-emerald-500/10 flex items-center justify-center">
              <svg class="w-7 h-7 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"/>
              </svg>
            </div>
            <h3 class="font-display font-bold text-white mb-2">ซัพพอร์ต 24/7</h3>
            <p class="text-gray-500 text-sm">ทีมงานพร้อมช่วยเหลือคุณตลอด 24 ชั่วโมง</p>
          </div>
          <div class="card-glass p-6 text-center animate-fade-in-up" style="animation-delay:0.3s;">
            <div class="w-14 h-14 mx-auto mb-4 rounded-xl bg-pink-500/10 flex items-center justify-center">
              <svg class="w-7 h-7 text-pink-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
              </svg>
            </div>
            <h3 class="font-display font-bold text-white mb-2">อัพเดตฟรี</h3>
            <p class="text-gray-500 text-sm">อัพเดตตลอดอายุการใช้งาน ไม่มีค่าใช้จ่ายเพิ่มเติม</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-24 relative">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <div class="card-glass p-12 md:p-16 relative overflow-hidden animate-fade-in-up">
          <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-primary-500 via-accent-500 to-primary-500 animate-gradient-shift" style="background-size: 200% 100%;"></div>
          <div class="absolute inset-0 bg-gradient-to-br from-primary-500/5 to-accent-500/5"></div>
          <div class="relative z-10">
            <h2 class="font-display text-3xl md:text-4xl font-bold text-white mb-4">
              พร้อมยกระดับเซิร์ฟเวอร์ของคุณ?
            </h2>
            <p class="text-gray-400 text-lg mb-8 max-w-2xl mx-auto">
              เข้าร่วมกับเซิร์ฟเวอร์กว่า 500+ ที่ไว้วางใจ NT SHOP
            </p>
            <div class="flex flex-wrap justify-center gap-4">
              <a href="/products" class="btn-primary text-lg">
                เริ่มช้อปเลย
                <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                </svg>
              </a>
              <a href="https://discord.gg" target="_blank" class="btn-secondary text-lg">
                <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/></svg>
                Discord Server
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>
  <script src="/js/main.js"></script>
</body>
</html>
